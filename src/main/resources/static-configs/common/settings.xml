<?xml version="1.0" encoding="UTF-8"?>
<settings xmlns="http://maven.apache.org/SETTINGS/1.2.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.2.0 https://maven.apache.org/xsd/settings-1.2.0.xsd">

    <mirrors>
        <mirror>
            <id>menora-artifactory</id>
            <name>Menora Artifactory</name>
            <mirrorOf>*</mirrorOf>
            <url>https://repo.menora.co.il/artifactory/libs-release</url>
        </mirror>
    </mirrors>

    <servers>
        <server>
            <id>menora-release</id>
            <username>${env.ARTIFACTORY_USER}</username>
            <password>${env.ARTIFACTORY_PASSWORD}</password>
        </server>
        <server>
            <id>menora-snapshot</id>
            <username>${env.ARTIFACTORY_USER}</username>
            <password>${env.ARTIFACTORY_PASSWORD}</password>
        </server>
    </servers>

    <profiles>
        <profile>
            <id>menora</id>
            <repositories>
                <repository>
                    <id>menora-release</id>
                    <name>Menora Artifactory Releases</name>
                    <url>https://repo.menora.co.il/artifactory/libs-release</url>
                    <releases><enabled>true</enabled></releases>
                    <snapshots><enabled>false</enabled></snapshots>
                </repository>
                <repository>
                    <id>menora-snapshot</id>
                    <name>Menora Artifactory Snapshots</name>
                    <url>https://repo.menora.co.il/artifactory/libs-snapshot</url>
                    <releases><enabled>false</enabled></releases>
                    <snapshots><enabled>true</enabled></snapshots>
                </repository>
            </repositories>
        </profile>
    </profiles>

    <activeProfiles>
        <activeProfile>menora</activeProfile>
    </activeProfiles>

</settings>
